SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY
# Opcional y heredado: solo si quieres mantener un fallback temporal a Apps Script.
# APPS_SCRIPT_API_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec
# Token compartido para permitir que el Worker pida envio de correos de cita al bridge de Apps Script.
# Debe coincidir con Script Property: VIDAFEM_WORKER_BRIDGE_TOKEN (o WORKER_BRIDGE_TOKEN).
WORKER_BRIDGE_TOKEN=CAMBIA_ESTE_TOKEN
# Opcional: varios tokens (separados por coma/espacio) para migracion gradual.
# WORKER_BRIDGE_TOKENS=TOKEN_ANTERIOR,TOKEN_NUEVO
SESSION_TTL_SECONDS=21600
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://ecumbe.github.io
# R2 se configura por binding en wrangler.toml:
# [[r2_buckets]]
# binding = "ASSETS_BUCKET"
# bucket_name = "vidafem-private"
